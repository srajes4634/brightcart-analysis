import pandas as pd

orders = pd.read_csv('../data/BrightCart_orders.csv')
marketing = pd.read_csv('../data/BrightCart_marketing_spend.csv')

# Category profitability
category = orders.groupby('category').agg({
    'revenue':'sum',
    'cost':'sum',
    'profit':'sum'
})
category['margin'] = category['profit'] / category['revenue']

print(category)

# Channel performance
channel = orders.groupby('channel').agg({
    'revenue':'mean',
    'profit':'sum',
    'return_flag':'mean'
})

print(channel)

# Returns impact
returns_loss = orders[orders['return_flag']==1]['revenue'].sum()
print("Revenue lost to returns:", returns_loss)

# Marketing ROAS
marketing['roas'] = marketing['revenue_attributed'] / marketing['spend']
print(marketing.groupby('platform')['roas'].mean())